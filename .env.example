# Copia questo file in .env e inserisci le tue chiavi reali.
# Il file .env è gitignored e non verrà mai pubblicato.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# CORS: origini consentite per il frontend (separare con virgola se multiple)
# Default: localhost:5173 e 127.0.0.1:5173 (sviluppo locale)
# In produzione: imposta l'URL reale del tuo frontend
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
